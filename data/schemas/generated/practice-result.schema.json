{
  "$id": "lease-companion/practice-result-v1.9.0.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "점수 없이 행동·신호·공식 근거로 구성한 최종 복기.",
  "properties": {
    "confirmed_action_ids": {
      "items": {
        "type": "string"
      },
      "title": "Confirmed Action Ids",
      "type": "array"
    },
    "confirmed_actions": {
      "items": {
        "type": "string"
      },
      "title": "Confirmed Actions",
      "type": "array"
    },
    "missed_action_ids": {
      "items": {
        "type": "string"
      },
      "title": "Missed Action Ids",
      "type": "array"
    },
    "missed_signals": {
      "items": {
        "type": "string"
      },
      "title": "Missed Signals",
      "type": "array"
    },
    "next_actions": {
      "items": {
        "type": "string"
      },
      "title": "Next Actions",
      "type": "array"
    },
    "official_source_ids": {
      "items": {
        "type": "string"
      },
      "title": "Official Source Ids",
      "type": "array"
    },
    "recommended_phrases": {
      "items": {
        "type": "string"
      },
      "title": "Recommended Phrases",
      "type": "array"
    },
    "scenario_id": {
      "pattern": "^PRACTICE-[A-Z0-9-]+-\\d{3}$",
      "title": "Scenario Id",
      "type": "string"
    },
    "scenario_version": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "title": "Scenario Version",
      "type": "string"
    },
    "schema_version": {
      "default": "1.9.0",
      "enum": [
        "1.8.0",
        "1.9.0"
      ],
      "title": "Schema Version",
      "type": "string"
    },
    "selected_action": {
      "anyOf": [
        {
          "enum": [
            "진행",
            "추가 확인",
            "특약 수정 요구",
            "보류",
            "중단"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Selected Action"
    },
    "session_id": {
      "minLength": 1,
      "title": "Session Id",
      "type": "string"
    }
  },
  "required": [
    "session_id",
    "scenario_id",
    "scenario_version"
  ],
  "title": "PracticeResult",
  "type": "object",
  "x-schema-version": "1.9.0"
}
