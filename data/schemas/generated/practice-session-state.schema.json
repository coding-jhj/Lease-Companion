{
  "$defs": {
    "PracticeTurnEvaluation": {
      "additionalProperties": false,
      "description": "연습 행동 평가 결과. 계약 규칙 상태와 분리한다.",
      "properties": {
        "answer_category": {
          "enum": [
            "appropriate_check",
            "partial_check",
            "ambiguous_answer",
            "avoidance",
            "no_response",
            "needs_review"
          ],
          "title": "Answer Category",
          "type": "string"
        },
        "confirmed_action_ids": {
          "items": {
            "type": "string"
          },
          "title": "Confirmed Action Ids",
          "type": "array"
        },
        "evidence_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Text"
        },
        "fallback_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fallback Reason"
        },
        "next_dialogue_state": {
          "minLength": 1,
          "title": "Next Dialogue State",
          "type": "string"
        },
        "schema_version": {
          "default": "1.9.0",
          "enum": [
            "1.8.0",
            "1.9.0"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "turn_id": {
          "pattern": "^TURN-\\d{2}$",
          "title": "Turn Id",
          "type": "string"
        },
        "verbal_reliance": {
          "default": "not_observed",
          "enum": [
            "not_observed",
            "relied",
            "rejected"
          ],
          "title": "Verbal Reliance",
          "type": "string"
        }
      },
      "required": [
        "turn_id",
        "answer_category",
        "next_dialogue_state"
      ],
      "title": "PracticeTurnEvaluation",
      "type": "object"
    }
  },
  "$id": "lease-companion/practice-session-state-v1.9.0.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "연습 세션의 복원 가능한 현재 상태.",
  "properties": {
    "completed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Completed At"
    },
    "confirmed_action_ids": {
      "items": {
        "type": "string"
      },
      "title": "Confirmed Action Ids",
      "type": "array"
    },
    "contract_or_signing_held": {
      "default": false,
      "title": "Contract Or Signing Held",
      "type": "boolean"
    },
    "current_state": {
      "minLength": 1,
      "title": "Current State",
      "type": "string"
    },
    "document_or_clause_requested": {
      "default": false,
      "title": "Document Or Clause Requested",
      "type": "boolean"
    },
    "evaluations": {
      "items": {
        "$ref": "#/$defs/PracticeTurnEvaluation"
      },
      "title": "Evaluations",
      "type": "array"
    },
    "evidence_texts": {
      "items": {
        "type": "string"
      },
      "title": "Evidence Texts",
      "type": "array"
    },
    "no_response_counts": {
      "additionalProperties": {
        "type": "integer"
      },
      "title": "No Response Counts",
      "type": "object"
    },
    "payment_held": {
      "default": false,
      "title": "Payment Held",
      "type": "boolean"
    },
    "recognized_signal_ids": {
      "items": {
        "type": "string"
      },
      "title": "Recognized Signal Ids",
      "type": "array"
    },
    "scenario_id": {
      "pattern": "^PRACTICE-[A-Z0-9-]+-\\d{3}$",
      "title": "Scenario Id",
      "type": "string"
    },
    "scenario_version": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "title": "Scenario Version",
      "type": "string"
    },
    "schema_version": {
      "default": "1.9.0",
      "enum": [
        "1.8.0",
        "1.9.0"
      ],
      "title": "Schema Version",
      "type": "string"
    },
    "selected_action": {
      "anyOf": [
        {
          "enum": [
            "진행",
            "추가 확인",
            "특약 수정 요구",
            "보류",
            "중단"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Selected Action"
    },
    "session_id": {
      "minLength": 1,
      "title": "Session Id",
      "type": "string"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "status": {
      "enum": [
        "active",
        "completed",
        "abandoned"
      ],
      "title": "Status",
      "type": "string"
    },
    "user_id": {
      "exclusiveMinimum": 0,
      "title": "User Id",
      "type": "integer"
    },
    "verbal_reliance": {
      "default": "not_observed",
      "enum": [
        "not_observed",
        "relied",
        "rejected",
        "mixed"
      ],
      "title": "Verbal Reliance",
      "type": "string"
    }
  },
  "required": [
    "session_id",
    "user_id",
    "scenario_id",
    "scenario_version",
    "current_state",
    "started_at",
    "status"
  ],
  "title": "PracticeSessionState",
  "type": "object",
  "x-schema-version": "1.9.0"
}
