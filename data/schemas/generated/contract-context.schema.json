{
  "$defs": {
    "ContractStage": {
      "enum": [
        "계약금 입금 전",
        "서명 전",
        "계약 직후"
      ],
      "title": "ContractStage",
      "type": "string"
    },
    "ContractType": {
      "enum": [
        "전세",
        "보증부 월세",
        "일반 월세"
      ],
      "title": "ContractType",
      "type": "string"
    }
  },
  "$id": "lease-companion/contract-context-v1.9.0.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "계약 상황 입력 — 스냅샷에 포함되는 불변 분석 입력.",
  "properties": {
    "balance_payment_date": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Balance Payment Date"
    },
    "contract_id": {
      "exclusiveMinimum": 0,
      "title": "Contract Id",
      "type": "integer"
    },
    "contract_stage": {
      "$ref": "#/$defs/ContractStage"
    },
    "contract_type": {
      "$ref": "#/$defs/ContractType"
    },
    "deposit_paid": {
      "title": "Deposit Paid",
      "type": "boolean"
    },
    "is_proxy_contract": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Is Proxy Contract"
    },
    "move_in_date": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Move In Date"
    },
    "schema_version": {
      "default": "1.9.0",
      "enum": [
        "1.8.0",
        "1.9.0"
      ],
      "title": "Schema Version",
      "type": "string"
    },
    "signed": {
      "title": "Signed",
      "type": "boolean"
    }
  },
  "required": [
    "contract_id",
    "contract_type",
    "contract_stage",
    "deposit_paid",
    "signed"
  ],
  "title": "ContractContext",
  "type": "object",
  "x-schema-version": "1.9.0"
}
