{
  "$id": "lease-companion/practice-turn-evaluation-v1.9.0.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "연습 행동 평가 결과. 계약 규칙 상태와 분리한다.",
  "properties": {
    "answer_category": {
      "enum": [
        "appropriate_check",
        "partial_check",
        "ambiguous_answer",
        "avoidance",
        "no_response",
        "needs_review"
      ],
      "title": "Answer Category",
      "type": "string"
    },
    "confirmed_action_ids": {
      "items": {
        "type": "string"
      },
      "title": "Confirmed Action Ids",
      "type": "array"
    },
    "fallback_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fallback Reason"
    },
    "next_dialogue_state": {
      "minLength": 1,
      "title": "Next Dialogue State",
      "type": "string"
    },
    "schema_version": {
      "default": "1.9.0",
      "enum": [
        "1.8.0",
        "1.9.0"
      ],
      "title": "Schema Version",
      "type": "string"
    },
    "turn_id": {
      "pattern": "^TURN-\\d{2}$",
      "title": "Turn Id",
      "type": "string"
    }
  },
  "required": [
    "turn_id",
    "answer_category",
    "next_dialogue_state"
  ],
  "title": "PracticeTurnEvaluation",
  "type": "object",
  "x-schema-version": "1.9.0"
}
