# 로컬 Docker PostgreSQL (docker-compose.yml 기준. 호스트 포트 5433 주의)
DATABASE_URL=postgresql+psycopg://lease:lease_dev_only@localhost:5433/lease_companion

# JWT 서명 키 (HS256은 32바이트 이상. 메인 서버 전환·운영 시 비밀값으로 교체)
JWT_SECRET=change-me-dev-secret-at-least-32-bytes

# 선택적 로컬 개발 시드. 세 값을 모두 명시할 때만 생성된다.
DEV_SEED_USERNAME=
DEV_SEED_EMAIL=
DEV_SEED_PASSWORD=

# 선택적 Hybrid RAG. 키가 없으면 공식자료 BM25 경로로 동작한다.
# 실제 유료 호출은 비용·키 사용 승인 후 설정한다.
GEMINI_API_KEY=
COHERE_API_KEY=

# 계약 연습: Gemini 키가 없을 때 승인 answer-key Fake provider를 사용한다.
# API 키가 있으면 이 값과 관계없이 Gemini practice provider가 우선한다.
PRACTICE_OFFLINE_MODE=true

# 문서 업로드 제한 — 로컬 MVP 임시값. 단일 원본은 ai/ingestion/limits.py.
DOCUMENT_MAX_FILE_BYTES=10485760
DOCUMENT_MAX_PDF_PAGES=20
DOCUMENT_MAX_IMAGE_DIMENSION=6000
DOCUMENT_MAX_IMAGE_PIXELS=40000000
DOCUMENT_MAX_PDF_RENDER_PIXELS=80000000
DOCUMENT_PDF_VALIDATION_DPI=150
DOCUMENT_MAX_CONCURRENT_VLM_CALLS=2
DOCUMENT_MAX_EXTERNAL_CALLS_PER_REQUEST=2
