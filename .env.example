# 슬기로운 계약생활 — 환경변수 예시.
# 실제 값·비밀정보를 넣지 않는다. 이 파일만 Git에 커밋한다.
# 미확정 항목은 주석으로 표시. 확정 후 값 채우고 .env 로 복사해 사용.

# === 애플리케이션 환경 ===
APP_ENV=development          # development | staging | production
LOG_LEVEL=info

# === 백엔드 호스트/포트 ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# === 데이터베이스 (확정: PostgreSQL — 2026-07-16 ADR. 접속 정보는 구현 시 작성) ===
# DATABASE_URL=

# === LLM API 키 (확정: 구조화·OCR = Gemini 3.5 Flash — 2026-07-14 선정표) ===
# 스캔 PDF OCR·구조화 추출에 필요. 없으면 정규식 파서 폴백(디지털 PDF/TXT만).
# GEMINI_API_KEY=
# GEMINI_MODEL_PRACTICE=gemini-3.5-flash
# GEMINI_MODEL_PRACTICE_FALLBACK=gemini-2.5-flash
# GEMINI_MODEL_CLASSIFICATION=gemini-3.5-flash
# GEMINI_MODEL_EXTRACTION=gemini-3.5-flash
# GEMINI_MODEL_GENERATION=gemini-3.5-flash
# GEMINI_MAX_CONCURRENCY=1
# 실제 AI Studio 프로젝트 한도를 확인한 경우에만 설정한다.
# GEMINI_REQUESTS_PER_MINUTE=
# 기본값은 미설정. 승인된 실제 연습 평가 smoke에서만 1로 설정한다.
# RUN_GEMINI_PRACTICE_SMOKE=1

# === 생성 LLM (2026-07-20 변경: Gemini 3.5 Flash — 위 GEMINI_API_KEY 재사용) ===

# === 임베딩·리랭커 (확정: gemini-embedding-001 + BM25 → Cohere rerank-v4.0-pro — 구현 전) ===

# === 벡터 저장소 (확정: Chroma 로컬 모드 — 2026-07-16 ADR. 구현 시 경로 작성) ===
# VECTOR_STORE=
# VECTOR_STORE_URL=

# === 파일 업로드 제한 ===
MAX_UPLOAD_SIZE_MB=10
MAX_FILES_PER_SESSION=10

# === 허용 파일 형식 ===
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf
