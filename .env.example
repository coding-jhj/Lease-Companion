# 슬기로운 계약생활 — 환경변수 예시
# 실제 값·비밀정보를 넣지 않는다. 이 파일만 Git에 커밋한다.
# 미확정 항목은 주석으로 표시. 확정 후 값 채우고 .env 로 복사해 사용.

# === 애플리케이션 환경 ===
APP_ENV=development          # development | staging | production
LOG_LEVEL=info

# === 백엔드 호스트/포트 ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# === 데이터베이스 (영속 저장 필요=확정 / 구체 제품 미정=TODO) ===
# 회원·계약 건·문서·분석 결과·체크리스트 저장에 필요. 제품 확정 후 작성.
# DATABASE_URL=

# === 인증 (회원 기능=MVP 확정 / 구현 기술·라이브러리 미정=TODO) ===
# AUTH_SECRET=
# AUTH_TOKEN_TTL=

# === 상용 LLM (하이브리드 사용=방향 확정 / 제공자·모델 미정=TODO) ===
# 저신뢰 결과 재검토, 설명·질문·행동 생성.
# COMMERCIAL_LLM_PROVIDER=
# COMMERCIAL_LLM_MODEL=
# COMMERCIAL_LLM_API_KEY=
# 할당량 소진·장애 대비 fallback 순서 (routing 모듈에서 사용)
# COMMERCIAL_LLM_FALLBACK=

# === 로컬 7B 모델 (파인튜닝 사용=방향 확정 / 베이스 모델·서빙 방식 미정=TODO) ===
# 조항 유형·명확성 후보 분류. 가중치·어댑터는 Git 미포함.
# LOCAL_MODEL_PATH=
# LOCAL_MODEL_ENDPOINT=

# === OCR (적용=확정 / 라이브러리 미정=TODO) ===
# OCR_PROVIDER=

# === VLM 보조 (보조 사용=방향 확정 / 모델 미정=TODO) ===
# VLM_MODEL=

# === 임베딩 모델 (TODO: 미확정) ===
# EMBEDDING_PROVIDER=
# EMBEDDING_MODEL=

# === 벡터 저장소 (TODO: 벡터 DB 미확정) ===
# VECTOR_STORE=
# VECTOR_STORE_URL=

# === 파일 업로드 제한 ===
MAX_UPLOAD_SIZE_MB=10
MAX_FILES_PER_UPLOAD=10

# === 허용 파일 형식 ===
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf
